SECRET_KEY=your-django-secret-key
DEBUG=True
DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage (S3-compatible) — create bucket "order-files" (private)
AWS_ACCESS_KEY_ID=your-s3-access-key-id
AWS_SECRET_ACCESS_KEY=your-s3-secret-access-key
AWS_S3_ENDPOINT_URL=https://your-project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_BUCKET=order-files
AWS_S3_REGION_NAME=auto

# Vercel cron: daily purge of order files after retention
CRON_SECRET=generate-a-long-random-string
